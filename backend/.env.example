# Perfil Spring (em Railway/produção use: SPRING_PROFILES_ACTIVE=prod)
# SPRING_PROFILES_ACTIVE=prod

# Database Configuration
DB_HOST=seu-host.neon.tech
DB_PORT=5432
DB_NAME=nome_do_banco
DB_USERNAME=usuario
DB_PASSWORD=ROTACIONE_ESTA_SENHA

# JWT Configuration (OBRIGATÓRIA em produção)
# Gere com: openssl rand -base64 64 | tr -d '\n'
# Deve ser Base64 padrão com padding (=), mínimo 32 bytes decodificados
JWT_SECRET=GERE_64_BYTES_ALEATORIOS_VIA_SECURERANDOM

# Mail (recuperação de senha) - Brevo ou Gmail
BREVO_API_KEY=xkeysib-xxxxxxxxxxxx
MAIL_FROM=seu-email@exemplo.com
# Se usar Gmail com App Password:
MAIL_PASSWORD=ROTACIONE_ESTA_APP_PASSWORD

# Mercado Pago (assinaturas)
MP_ACCESS_TOKEN=APP_USR-xxxx
MP_PUBLIC_KEY=APP_USR-xxxx
# OBRIGATÓRIO EM PRODUÇÃO: MP_WEBHOOK_SECRET deve estar configurado. Sem ele, webhooks rejeitam com 503.
# Obter em: Suas integrações > Webhooks ao cadastrar a URL
MP_WEBHOOK_SECRET=sua_chave_secreta_webhook

# Pluggy Open Finance (plano Elite)
PLUGGY_CLIENT_ID=seu-client-id-uuid
PLUGGY_CLIENT_SECRET=seu-client-secret

# CORS — obrigatório (a aplicação não inicia sem esta variável no application.properties)
# Formato: URL exata sem aspas. Múltiplas: separar por vírgula.
APP_CORS_ORIGINS=https://grivy.netlify.app,https://www.grivy.netlify.app,http://localhost:3000,http://localhost:5173

# URL pública do frontend (e-mails, Open Finance)
APP_FRONTEND_URL=https://grivy.netlify.app
APP_URL=https://grivy.netlify.app

# URL pública do backend (webhooks MP — deve ser HTTPS em produção)
APP_WEBHOOK_BASE_URL=https://seu-backend.up.railway.app
