# --- Backend (Spring Boot) — copie para backend/.env ---
JWT_SECRET=
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USERNAME=
DB_PASSWORD=

APP_FRONTEND_URL=https://grivy.netlify.app
APP_CORS_ORIGINS=https://grivy.netlify.app

# E-mail: use Resend (preferencial) OU Brevo (legado)
RESEND_API_KEY=
BREVO_API_KEY=
MAIL_FROM=grivycontrolefinanceiro@gmail.com

APP_REQUIRE_EMAIL_VERIFICATION=false
APP_PASSWORD_RESET_MIN_DURATION_MS=200

# Mercado Pago
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# Open Finance (Pluggy)
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=

# WhatsApp Cloud API (Meta)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# OpenAI (fallback extração de mensagens WhatsApp)
OPENAI_API_KEY=

# --- Frontend (Nuxt) — copie para frontend/.env ---
NUXT_PUBLIC_API_BASE=https://your-api.example.com/api
NUXT_PUBLIC_MP_PUBLIC_KEY=
